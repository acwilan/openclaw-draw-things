{
  "name": "@acwilan/openclaw-draw-things",
  "version": "1.1.7",
  "description": "Monorepo for OpenClaw Draw Things plugin and skill - local AI image generation",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf packages/*/dist packages/*/node_modules",
    "publish:plugin": "cd packages/plugin && npm run publish:clawhub",
    "install:skill": "echo 'Copy packages/skill to ~/.openclaw/skills/draw-things'"
  },
  "keywords": [
    "openclaw",
    "draw-things",
    "image-generation",
    "ai",
    "monorepo"
  ],
  "author": "acwilan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/acwilan/openclaw-draw-things.git"
  },
  "engines": {
    "node": ">=22"
  }
}
